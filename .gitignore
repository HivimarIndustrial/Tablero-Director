!automatizacion/odoo_mapeo_definitivo.json
automatizacion/*.txt
automatizacion/*.eml
automatizacion/*.png
automatizacion/probes_*
automatizacion/hallazgos_*
automatizacion/profiler_*
automatizacion/qlik_apps_*
automatizacion/raw_sheets_*
automatizacion/cartera_kgtrxf*
automatizacion/excel_*

