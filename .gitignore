# === SECRETOS ============================================================
claves.json
*.password
.env
credenciales*
secrets*
**/credenciales/
*.pem
*.key

# === DATOS SENSIBLES (Excel, salida cruda, dumps) ========================
*.xlsx
~$*.xlsx
*.csv
salida_raw/
Datos RAW/
db_output*.js
data.json
data_embedded.json

# === HTMLs en CLARO (con datos sin cifrar) — solo se sube docs/ ==========
*.html
!docs/*.html
*.html.bak*
*.html.backup*
*.prepatch

# === Documentos internos (Word/PDF) — pueden tener info sensible ========
